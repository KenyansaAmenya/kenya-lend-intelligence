# KENYA LEND INTELLIGENCE - ENVIRONMENT CONFIGURATION

# APPLICATION SETTINGS
APP_NAME=KenyaLendIntelligence
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# DATABASE - SUPABASE POSTGRESQL
# Development
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kenya_lend_dev
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/kenya_lend_dev

# Production (Supabase)
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# DATABASE_URL_SYNC=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# SUPABASE CONFIGURATION
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Storage Buckets
STORAGE_BUCKET_RAW=raw-statements
STORAGE_BUCKET_PROCESSED=processed-data
STORAGE_BUCKET_MODELS=ml-models
STORAGE_BUCKET_ARTIFACTS=ml-artifacts


# SECURITY
ALGORITHM=HS256
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
RATE_LIMIT_PER_MINUTE=60

# ML MODEL CONFIGURATION
MODEL_PATH=./ml/models
CREDIT_MODEL_PATH=./ml/models/credit_model.pkl
DEFAULT_MODEL_PATH=./ml/models/default_model.pkl
CHURN_MODEL_PATH=./ml/models/churn_model.pkl
PREPROCESSOR_PATH=./ml/models/preprocessor.pkl

# Model Training
TRAIN_TEST_SPLIT=0.7
VALIDATION_SPLIT=0.15
TEST_SPLIT=0.15
RANDOM_STATE=42
N_TRIALS_OPTUNA=100

# CHURN CONFIGURATION
CHURN_INACTIVITY_DAYS=90
CHURN_LOOKBACK_DAYS=30

# CREDIT SCORING
MIN_CREDIT_SCORE=300
MAX_CREDIT_SCORE=850
BASE_INTEREST_RATE=0.15
MAX_INTEREST_RATE=0.36

# EXTERNAL DATA CONNECTORS
# World Bank API
WORLD_BANK_API_URL=https://api.worldbank.org/v2

# Kaggle
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# LOGGING
LOG_LEVEL=INFO
LOG_FORMAT=json

# FEATURE ENGINEERING
MAX_FEATURES=40
FEATURE_STORE_ENABLED=false